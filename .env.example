# Obsidian wiki vault — checked into https://github.com/<owner>/<repo>.wiki.git
OBSIDIAN_VAULT_PATH=~/wiki/<repo>
pl
# Source directories to ingest from (comma-separated)
# Point this at folders containing documents, articles, notes, etc. you want
# distilled into the wiki. This is NOT your project source code — it's raw
# knowledge material (PDFs, markdown notes, exports, etc.).
# OBSIDIAN_SOURCES_DIR=~/Documents

# QMD collections for semantic search in wiki-query (optional)
# QMD_WIKI_COLLECTION=
# QMD_PAPERS_COLLECTION=
