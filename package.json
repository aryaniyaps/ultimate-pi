{
  "name": "ultimate-pi",
  "version": "0.1.2",
  "description": "Custom pi package starter",
  "keywords": [
    "pi-package",
    "pi-mono",
    "pi",
    "ai-harness",
    "coding-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aryaniyaps/ultimate-pi"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./.agents/skills"
    ]
  },
  "scripts": {
    "bench:terminal": "./bench/terminal-bench/run-terminal-bench.sh",
    "check:ts": "tsc --noEmit --target ES2022 --moduleResolution nodenext --module nodenext --skipLibCheck lib/auto-commit-core.ts extensions/auto-commit-pane.ts extensions/auto-commit-orchestrator.ts extensions/lean-ctx-enforce.ts",
    "test": "node --experimental-strip-types --test"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "0.70.2",
    "typescript": "^6.0.3"
  }
}