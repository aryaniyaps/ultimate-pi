{
	"name": "ultimate-pi",
	"version": "0.1.2",
	"description": "Custom pi package starter",
	"keywords": [
		"pi-package",
		"pi-mono",
		"pi",
		"ai-harness",
		"coding-agent"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/aryaniyaps/ultimate-pi"
	},
	"pi": {
		"extensions": [
			"./.pi/extensions"
		],
		"skills": [
			"./.agents/skills"
		]
	},
	"scripts": {
		"bench:terminal": "./bench/terminal-bench/run-terminal-bench.sh",
		"check:ts": "tsc --noEmit --target ES2022 --moduleResolution nodenext --module nodenext --skipLibCheck .pi/extensions/dotenv-loader.ts",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"format": "biome format --write",
		"format:check": "biome format",
		"prepare": "lefthook install",
		"test": "node --experimental-strip-types --test"
	},
	"devDependencies": {
		"@biomejs/biome": "2.0.6",
		"@mariozechner/pi-coding-agent": "0.70.2",
		"lefthook": "1.11.13",
		"typescript": "^6.0.3"
	}
}
