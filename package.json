{
	"name": "ultimate-pi",
	"version": "0.1.3",
	"description": "Ultimate AI coding harness for pi.dev — extensible skills, Obsidian wiki knowledge layer, compressed context, deterministic output",
	"keywords": [
		"pi-package",
		"pi-mono",
		"pi",
		"ai-harness",
		"coding-agent",
		"obsidian-wiki",
		"knowledge-base",
		"context-compression",
		"agent-skills",
		"cursor-sdk",
		"firecrawl",
		"lean-ctx",
		"vcc"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/aryaniyaps/ultimate-pi"
	},
	"pi": {
		"extensions": [
			"./.pi/extensions",
			"./.pi/providers"
		],
		"skills": [
			"./.agents/skills"
		]
	},
	"scripts": {
		"check:ts": "tsc --noEmit --target ES2022 --moduleResolution nodenext --module nodenext --skipLibCheck .pi/extensions/dotenv-loader.ts",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"format": "biome format --write",
		"format:check": "biome format",
		"prepare": "lefthook install",
		"test": "node --experimental-strip-types --test",
		"test:integration": "npx -y tsx --test test/cursor-sdk-provider.integration.test.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.0.6",
		"@mariozechner/pi-coding-agent": "0.70.2",
		"@sinclair/typebox": "^0.34.49",
		"lefthook": "1.11.13",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@cursor/sdk": "^1.0.12",
		"@sting8k/pi-vcc": "^0.3.12",
		"asciify-image": "^0.1.10"
	}
}